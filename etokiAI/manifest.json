{
  "manifest_version": 3,
  "name": "etokiAI",
  "version": "1.0.0",
  "description": "AI page summarizer for web articles.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>", "http://localhost:3000/*"], 
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "etokiAI",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}